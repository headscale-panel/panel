# Frontend env for local development

# Backend API base URL used by browser runtime requests.
VITE_API_URL=/panel/api/v1

# Optional WebSocket host. Leave empty to auto-use current origin.
# Example: ws://localhost:3000
VITE_WS_URL=

# OAuth portal base URL used to build login redirects.
VITE_OAUTH_PORTAL_URL=http://localhost:8080

# OAuth application ID from your auth portal.
VITE_APP_ID=headscale-panel

# Google Maps proxy API key used by MapView.
VITE_FRONTEND_FORGE_API_KEY=replace_with_real_key

# Optional Forge API base URL for map proxy.
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# Vite dev-server proxy target (used by vite.config.ts in Node context).
VITE_API_PROXY_TARGET=http://localhost:8080