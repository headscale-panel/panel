# Frontend env for local development

# Backend API base URL used by browser runtime requests.
VITE_API_URL=/panel/api/v1

# Optional WebSocket host. Leave empty to auto-use current origin.
# Example: ws://localhost:3000
VITE_WS_URL=

# Vite dev-server proxy target (used by vite.config.ts in Node context).
VITE_API_PROXY_TARGET=http://localhost:8080