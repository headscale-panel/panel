# External dependencies for local development

# Host port for Headscale HTTP API.
HEADSCALE_HTTP_PORT=5080

# Host port for Headscale gRPC API.
HEADSCALE_GRPC_PORT=50443

# Run DERP with: WITH_DERP=true ./shell/dev/start.sh

# Public domain used by DERP clients.
DERP_DOMAIN=derp.example.com

# TLS mode for DERP: letsencrypt | manual | disable.
DERP_CERT_MODE=letsencrypt

# DERP listen address inside container.
DERP_ADDR=:443

# HTTP port for DERP debug/plain mode.
DERP_HTTP_PORT=-1

# UDP STUN port for DERP NAT traversal.
DERP_STUN_PORT=3478

# Go module proxy used when building DERP image.
GOPROXY=https://proxy.golang.org,direct

# Run InfluxDB with: WITH_INFLUXDB=true ./shell/dev/start.sh

# Host port for InfluxDB UI and API.
INFLUXDB_HOST_PORT=8086

# InfluxDB admin credentials (used for first-time setup).
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=adminpassword

# InfluxDB settings that must match the backend .env values.
INFLUXDB_TOKEN=dev-influxdb-token
INFLUXDB_ORG=headscale-panel
INFLUXDB_BUCKET=metrics
