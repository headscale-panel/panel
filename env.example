# Headscale Panel 环境变量配置

# 后端配置
BACKEND_PORT=8080
GIN_MODE=release

# 前端配置
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080

# Nginx 配置（如果使用 Nginx）
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# 时区
TZ=Asia/Shanghai

# 数据目录（宿主机路径）
DATA_DIR=./data

# Headscale 配置
HEADSCALE_HOST=headscale.example.com
HEADSCALE_PORT=8081

# DERP 配置
DERP_HOST=derp.example.com
DERP_PORT=3478

# SSL 配置
ENABLE_SSL=false
SSL_CERT_MODE=certbot
CERTBOT_EMAIL=admin@example.com
