# Backend env for local development

# Listen address for backend server.
SYSTEM_PORT=:8080

# Enable release mode when set to true.
SYSTEM_RELEASE=false

# Public base URL used by callbacks.
SYSTEM_BASE_URL=http://localhost:8080

# Optional bootstrap token for setup flow.
# SYSTEM_SETUP_BOOTSTRAP_TOKEN=

# SQLite database file path.
DB_PATH=data.db

# JWT signing secret (must be strong in production).
JWT_SECRET=dev_jwt_9Qf2xL7mN3pR8tV1kC6wZ0aB4dH5sY2

# JWT expiration time in hours.
JWT_EXPIRE=24

# Run `./shell/dev/start.sh` first.

# Headscale gRPC address for local backend.
HEADSCALE_GRPC_ADDR=localhost:50443

# Headscale API key generated from headscale container.
HEADSCALE_API_KEY=dev_hs_7f2a9c1e4b6d8a0c3e5f7a9b1c2d4e6f

# Skip TLS validation for local development.
HEADSCALE_INSECURE=true

# Optional path to Headscale config file.
# HEADSCALE_CONFIG_PATH=./headscale/config.yaml

# Optional path to Headscale extra DNS records.
# HEADSCALE_EXTRA_RECORDS_PATH=./headscale/extra-records.json

# Optional InfluxDB URL for metrics collection.
# INFLUXDB_URL=http://localhost:8086

# Optional InfluxDB token for authentication.
# INFLUXDB_TOKEN=your_influxdb_token_here

# InfluxDB organization name.
INFLUXDB_ORG=headscale-panel

# InfluxDB bucket name.
INFLUXDB_BUCKET=metrics

# Redis server address.
REDIS_ADDR=localhost:6379

# Redis password for protected instances.
REDIS_PASSWORD=dev_redis_4c1f8a7e2d9b6a3f

# Redis database index.
REDIS_DB=0
