# Backend env for local development

# Listen address for backend server.
SYSTEM_PORT=:8080

# Enable debug mode (verbose logging).
# SYSTEM_DEBUG=false

# Public base URL used by callbacks.
SYSTEM_BASE_URL=http://localhost:8080

# Optional bootstrap token for setup flow.
# SYSTEM_SETUP_BOOTSTRAP_TOKEN=

# JWT signing secret (must be strong in production).
JWT_SECRET=random_str

# JWT expiration time in hours.
JWT_EXPIRE=24

# InfluxDB URL for metrics collection (leave empty to disable).
INFLUXDB_URL=http://127.0.0.1:8086

# InfluxDB authentication token.
INFLUXDB_TOKEN=dev-influxdb-token

# InfluxDB organization name.
INFLUXDB_ORG=headscale-panel

# InfluxDB bucket name.
INFLUXDB_BUCKET=metrics

# Enable Docker-in-Docker style Headscale restarts for local development.
DOCKER_DIND_ENABLED=true

# Docker container name used when restarting Headscale after config updates.
DOCKER_HEADSCALE_CONTAINER_NAME=headscale
