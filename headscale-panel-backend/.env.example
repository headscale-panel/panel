# System Configuration
# 服务监听端口
SYSTEM_PORT=:8080
# 是否开启发布模式 (true/false)，发布模式下日志较少
SYSTEM_RELEASE=false
# 系统基础URL，用于OIDC Issuer和回调地址生成，必须配置为外部可访问的地址
SYSTEM_BASE_URL=http://localhost:8080

# Database Configuration
# SQLite 数据库文件路径
DB_PATH=data.db

# JWT Configuration
# JWT 签名密钥，请务必修改为随机字符串
JWT_SECRET=your_jwt_secret_key_here
# Token 过期时间 (小时)
JWT_EXPIRE=24

# Headscale Configuration
# Headscale gRPC 地址 (例如: localhost:50443)
HEADSCALE_GRPC_ADDR=localhost:50443
# Headscale API Key (通过 `headscale apikeys create` 生成)
HEADSCALE_API_KEY=your_headscale_api_key_here
# 是否跳过 TLS 证书验证 (如果 Headscale 使用自签名证书或未开启 TLS，设为 true)
HEADSCALE_INSECURE=true
