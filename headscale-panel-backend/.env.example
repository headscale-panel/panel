# ============================================================================
# Headscale Panel 环境配置
# ============================================================================
# 此文件定义了 Headscale Panel 后端的所有环境变量
# 复制此文件为 .env 并根据实际部署情况修改相应配置

# ============================================================================
# 系统配置 (SYSTEM_*)
# ============================================================================

# 服务监听地址和端口
# 格式: :PORT 或 HOST:PORT (例: :8080 或 127.0.0.1:8080)
SYSTEM_PORT=:8080

# 是否启用发布模式
# true:  生产环境，日志输出较少，CORS 严格限制
# false: 开发环境，日志详细，CORS 允许所有源
SYSTEM_RELEASE=false

# 系统基础 URL（外部可访问地址）
# - 用于 OIDC Issuer 和 OAuth2 回调 URL 生成
# - 必须是客户端能够访问的完整 URL (包括协议和端口)
# - 例: https://panel.example.com 或 http://localhost:8080
SYSTEM_BASE_URL=http://localhost:8080

# 初始化引导令牌（可选）
# - 用于首次部署时的初始管理员账户创建
# - 如果配置，必须 >= 32 个字符
# - 建议留空，通过前端引导界面创建
# SYSTEM_SETUP_BOOTSTRAP_TOKEN=

# ============================================================================
# 数据库配置 (DB_*)
# ============================================================================

# SQLite 数据库文件路径
# - 相对路径: 相对于应用工作目录
# - 绝对路径: /path/to/data.db
# - 确保目录存在且应用有读写权限
DB_PATH=data.db

# ============================================================================
# JWT 认证配置 (JWT_*)
# ============================================================================

# JWT 签名密钥（必须配置）
# - 最少 32 个字符的随机字符串
# - 用于签名和验证用户令牌
# - 修改此值会使所有现有令牌失效
# - 生成方式: openssl rand -base64 32
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars_long_

# 用户令牌过期时间（小时）
# - 用户登录获取的访问令牌有效期
JWT_EXPIRE=24

# ============================================================================
# Headscale 连接配置 (HEADSCALE_*)
# ============================================================================

# Headscale gRPC 服务地址
# - 例: localhost:50443 (本地开发)
# - 例: headscale.example.com:50443 (远程服务)
HEADSCALE_GRPC_ADDR=localhost:50443

# Headscale API Key
# - 通过以下命令在 Headscale 服务器生成:
#   headscale apikeys create --expiration 0 (不过期)
# - 此密钥用于认证 Headscale Panel 到 Headscale 的所有请求
HEADSCALE_API_KEY=your_headscale_api_key_here

# 是否跳过 TLS 证书验证
# true:  跳过验证 (用于自签名证书或未启用 TLS)
# false: 验证证书 (生产环境推荐)
HEADSCALE_INSECURE=true

# Headscale 配置文件路径（可选）
# - 如指定，Panel 将尝试读取和管理此配置文件
# - 例: /etc/headscale/config.yaml 或 ./headscale/config.yaml
# HEADSCALE_CONFIG_PATH=./headscale/config.yaml

# Headscale extra DNS 记录文件路径（可选）
# - 用于管理额外的 DNS 解析记录
# - 例: /var/lib/headscale/extra-records.json 或 ./headscale/extra-records.json
# HEADSCALE_EXTRA_RECORDS_PATH=./headscale/extra-records.json

# ============================================================================
# InfluxDB 时序数据库配置（可选，用于指标收集）(INFLUXDB_*)
# ============================================================================

# InfluxDB 连接地址
# - 例: http://localhost:8086 或 https://influxdb.example.com
# - 留空则禁用指标上报
# INFLUXDB_URL=http://localhost:8086

# InfluxDB 认证令牌
# - 通过 InfluxDB Web UI 或 CLI 生成
# INFLUXDB_TOKEN=your_influxdb_token_here

# InfluxDB Organization 名称
INFLUXDB_ORG=headscale-panel

# InfluxDB Bucket 名称（数据库名）
INFLUXDB_BUCKET=metrics

# ============================================================================
# Redis 缓存配置（可选，用于分布式缓存）(REDIS_*)
# ============================================================================

# Redis 服务地址
# - 本地: localhost:6379
# - 远程: redis.example.com:6379
REDIS_ADDR=localhost:6379

# Redis 认证密码
# - 如无密码则留空
REDIS_PASSWORD=

# Redis 逻辑数据库编号 (0-15)
REDIS_DB=0

# ============================================================================
# 安全建议
# ============================================================================
# 1. 生产环境下，务必:
#    - 修改 SYSTEM_BASE_URL 为实际的域名
#    - 修改 JWT_SECRET 为强随机密钥
#    - 启用 SYSTEM_RELEASE=true
#    - 设置 HEADSCALE_INSECURE=false 并配置有效的 TLS 证书
#    - 使用强密码保护数据库
#
# 2. 定期备份:
#    - 备份 DB_PATH 指向的数据库文件
#    - 备份 OIDC 签名密钥 (与数据库目录同级的 oidc_signing_key.pem)
#
# 3. 敏感信息:
#    - 不要将此文件提交到版本控制系统
#    - 在容器化部署中，通过密钥管理系统注入敏感值
# ============================================================================
